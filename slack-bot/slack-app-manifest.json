{
  "display_information": {
    "name": "Front Door",
    "description": "AI-powered hiring intake assistant",
    "background_color": "#18181b"
  },
  "features": {
    "bot_user": {
      "display_name": "Hiring Hub",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/hire",
        "description": "Start a new hiring request",
        "usage_hint": "Just type /hire to begin"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "commands",
        "im:history",
        "im:read",
        "im:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
